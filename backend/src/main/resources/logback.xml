<configuration>
    <variable name="LOG_LEVEL" value="${LOG_LEVEL:-DEBUG}" />

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%X{callId:-no-call}] [%X{userId:-anon}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <logger name="io.ktor" level="INFO"/>
    <logger name="com.kanjimasta" level="${LOG_LEVEL}"/>

    <!-- Suppress noisy third-party loggers -->
    <logger name="org.apache.http" level="WARN"/>
    <logger name="org.apache.hc" level="WARN"/>
    <logger name="com.google.auth" level="WARN"/>
    <logger name="io.grpc" level="WARN"/>
</configuration>
