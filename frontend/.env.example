# Local dev (.env) — loaded by `npm run dev`
VITE_API_URL=http://localhost:8080
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<from supabase start output>

# Production (.env.production) — loaded by `npm run build`
# Copy this section to .env.production with real values:
# VITE_API_URL=https://your-backend.asia-east1.run.app
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGc...
