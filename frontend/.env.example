# Local dev (.env) — loaded by `npm run dev`
VITE_API_URL=http://localhost:8080
VITE_FIREBASE_API_KEY=demo-key
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=demo-kanji-masta
VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
VITE_FIREBASE_STORAGE_BUCKET=demo-kanji-masta.appspot.com
VITE_FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Production (.env.production) — loaded by `npm run build`
# Copy this section to .env.production with real values:
# VITE_API_URL=https://your-backend.asia-east1.run.app
# VITE_FIREBASE_API_KEY=AIza...
# VITE_FIREBASE_AUTH_DOMAIN=kanji-masta.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=kanji-masta
# VITE_FIREBASE_STORAGE_BUCKET=kanji-masta.firebasestorage.app
# (no emulator hosts — connects to real Firebase)
